# =========================================================
# CoinVest Infrastructure Config (Production Ready Template)
# =========================================================

# [Environment]
# prod (배포) 또는 local (개발) 선택
SPRING_PROFILES_ACTIVE=prod

# [Database Shared Credentials]
DOCKERHUB_USERNAME=DOCKERHUB_USERNAME
DB_NAME=DB_NAME
DB_USER=DB_USER
DB_PASS=DB_PASS

# [Next.js API Access]
# 배포 시: /api/v1, 로컬 개발 시: http://localhost:8080/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# [Security - Do not leak in real .env!]
JWT_SECRET=JWT_SECRET
APP_SECURITY_AES_KEY=APP_SECURITY_AES_KEY

# [External APIs]
KIS_APP_KEY=KIS_APP_KEY
KIS_APP_SECRET=KIS_APP_SECRET
SYSTEM_DISCORD_WEBHOOK_URL=SYSTEM_DISCORD_WEBHOOK_URL
