# CoinVest Environment Variables Example
# Copy this file to .env and fill in the values.

# Spring Boot Profile
SPRING_PROFILES_ACTIVE=local

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://{DB_HOST}:{DB_PORT}/{DB_NAME}
DB_USERNAME={DB_USERNAME}
DB_PASSWORD={DB_PASSWORD}

# Redis
REDIS_HOST={REDIS_HOST}
REDIS_PORT={REDIS_PORT}

# Kafka
KAFKA_BOOTSTRAP_SERVERS={KAFKA_HOST}:{KAFKA_PORT}

# JWT Secret (Min 64 characters)
JWT_SECRET={YOUR_JWT_SECRET_KEY}

# Security (AES-256 Key - 32 bytes)
APP_SECURITY_AES_KEY={YOUR_32_BYTE_AES_KEY}

# KIS (한국투자증권) API
KIS_APP_KEY={YOUR_KIS_APP_KEY}
KIS_APP_SECRET={YOUR_KIS_APP_SECRET}

# Discord Webhooks
SYSTEM_DISCORD_WEBHOOK_URL={YOUR_DISCORD_WEBHOOK_URL}
