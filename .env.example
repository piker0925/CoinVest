# CoinVest Environment Variables Example
# Copy this file to .env and fill in the values.

# Spring Boot Profile
SPRING_PROFILES_ACTIVE=prod

# Frontend API URL (Next.js)
# 로컬 개발 시: http://localhost:8080/api/v1
# 서버 배포 시: /api/v1 (Nginx 프록시 이용 시)
NEXT_PUBLIC_API_URL=/api/v1

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://db:5432/coinvest
DB_USERNAME=coinvest
DB_PASSWORD=your_secure_password
POSTGRES_PASSWORD=your_secure_password # Docker 전용

# Redis
REDIS_HOST={REDIS_HOST}
REDIS_PORT={REDIS_PORT}

# Kafka
KAFKA_BOOTSTRAP_SERVERS={KAFKA_HOST}:{KAFKA_PORT}

# JWT Secret (Min 64 characters)
JWT_SECRET={YOUR_JWT_SECRET_KEY}

# Security (AES-256 Key - 32 bytes)
APP_SECURITY_AES_KEY={YOUR_32_BYTE_AES_KEY}

# KIS (한국투자증권) API
KIS_APP_KEY={YOUR_KIS_APP_KEY}
KIS_APP_SECRET={YOUR_KIS_APP_SECRET}

# Discord Webhooks
SYSTEM_DISCORD_WEBHOOK_URL={YOUR_DISCORD_WEBHOOK_URL}
